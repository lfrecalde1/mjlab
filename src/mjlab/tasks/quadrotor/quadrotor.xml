<mujoco model="quadrotor">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.01" gravity="0 0 -9.81" integrator="implicitfast"/>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>

    <body name="drone_0" pos="0 0 0.8" euler="0 0 0">
      <joint name="drone_0" type="free" damping="0.001"/>

      <geom name="core" type="box" size="0.035 0.035 0.015" rgba="1 1 0 1" mass="0.84"/>
      <geom name="arm_x" type="box" pos="0.071 0.071 0" size="0.05 0.01 0.0025" quat="0.924 0 0 0.383" rgba="1 0.5 0 1" mass="0.025"/>
      <geom name="arm_y" type="box" pos="0.071 -0.071 0" size="0.05 0.01 0.0025" quat="0.383 0 0 0.924" rgba="1 0.5 0 1" mass="0.025"/>
      <geom name="arm_z" type="box" pos="-0.071 -0.071 0" size="0.05 0.01 0.0025" quat="-0.383 0 0 0.924" rgba="1 0.5 0 1" mass="0.025"/>
      <geom name="arm_w" type="box" pos="-0.071 0.071 0" size="0.05 0.01 0.0025" quat="0.924 0 0 -0.383" rgba="1 0.5 0 1" mass="0.025"/>
      <geom name="axis_x" type="capsule" fromto="0 0 0 0.08 0 0" size="0.004" rgba="1 0 0 1" mass="0.001"/>
      <geom name="axis_y" type="capsule" fromto="0 0 0 0 0.08 0" size="0.004" rgba="0 1 0 1" mass="0.001"/>
      <geom name="axis_z" type="capsule" fromto="0 0 0 0 0 0.08" size="0.004" rgba="0 0 1 1" mass="0.001"/>

      <site name="thrust" type="sphere" pos="0 0 0" size="0.01" rgba="0 1 1 1"/>
      <site name="rateX" type="sphere" pos="0 0 0" size="0.01" rgba="0 1 1 1"/>
      <site name="rateY" type="sphere" pos="0 0 0" size="0.01" rgba="0 1 1 1"/>
      <site name="rateZ" type="sphere" pos="0 0 0" size="0.01" rgba="0 1 1 1"/>
      <camera name="drone_0_camera" pos="0.035 0 -0.05" euler="0 -1.2 -1.57"/>
      <site name="imu" pos="0 0 0"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="body_thrust" site="thrust" gear="0 0 1 0 0 0" ctrlrange="0 60"/>
    <motor name="x_moment" site="rateX" gear="0 0 0 1 0 0" ctrlrange="-0.3 0.3"/>
    <motor name="y_moment" site="rateY" gear="0 0 0 0 1 0" ctrlrange="-0.3 0.3"/>
    <motor name="z_moment" site="rateZ" gear="0 0 0 0 0 1" ctrlrange="-0.3 0.3"/>
  </actuator>
</mujoco>
